{
  "name": "poe2-crafting-helper",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first Path of Exile 2 crafting helper: browse bases & modifiers, reference crafting materials, plan crafting paths, price-check via poe2scout, and learn what sells via the PoE2 trade API.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "data:refresh": "tsx scripts/refresh-data.ts",
    "data:materials": "tsx scripts/refresh-materials.ts",
    "data:seed": "tsx scripts/seed-db.ts",
    "data:setup": "tsx scripts/refresh-data.ts && tsx scripts/refresh-materials.ts && tsx scripts/seed-db.ts",
    "trade:stats": "tsx scripts/sync-trade-stats.ts",
    "market:sample": "tsx scripts/sample-market.ts",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "drizzle-orm": "^0.38.3",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
